{
  "compilerOptions": {
    // https://github.com/microsoft/TypeScript/wiki/Node-Target-Mapping
    "lib": ["ES2024"],
    "types": ["node"],
    "module": "nodenext",
    "noEmit": true,
    "strict": true,
    "allowUnreachableCode": false,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "scripts",
    "*.config.ts"
  ]
}